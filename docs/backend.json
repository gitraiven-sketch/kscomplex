
{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "A tenant in the shopping complex.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the tenant."
        },
        "name": {
          "type": "string",
          "description": "The name of the tenant."
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the tenant."
        },
        "propertyId": {
          "type": "string",
          "description": "The ID of the property the tenant is renting."
        },
        "rentAmount": {
          "type": "number",
          "description": "The amount of rent due."
        },
        "paymentDay": {
          "type": "number",
          "description": "The day of the month rent is due."
        },
        "leaseStartDate": {
          "type": "string",
          "format": "date",
          "description": "The start date of the lease."
        },
        "lastPaidDate": {
          "type": "string",
          "format": "date-time",
          "description": "The last date a payment was recorded for this tenant."
        }
      },
      "required": [
        "name",
        "phone",
        "propertyId",
        "rentAmount",
        "paymentDay",
        "leaseStartDate"
      ]
    },
    "Property": {
        "title": "Property",
        "description": "A shop in the shopping complex.",
        "type": "object",
        "properties": {
            "id": {
                "type": "string",
                "description": "The unique identifier for the property."
            },
            "name": {
                "type": "string"
            },
            "group": {
                "type": "string"
            },
            "shopNumber": {
                "type": "number"
            },
            "address": {
                "type": "string"
            },
            "paymentDay": {
                "type": "number"
            }
        },
        "required": ["name", "group", "shopNumber", "address", "paymentDay"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A record of a single payment made by a tenant.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the payment."
        },
        "tenantId": {
          "type": "string",
          "description": "The ID of the tenant who made the payment."
        },
        "propertyId": {
          "type": "string",
          "description": "The ID of the property for which the payment was made."
        },
        "amount": {
          "type": "number",
          "description": "The amount paid."
        },
        "paymentDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date the payment was recorded for."
        },
        "recordedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the payment was recorded in the system."
        },
        "tenantName": {
          "type": "string",
          "description": "The name of the tenant (denormalized)."
        },
        "propertyName": {
          "type": "string",
          "description": "The name of the property (denormalized)."
        }
      },
      "required": ["tenantId", "propertyId", "amount", "paymentDate", "recordedAt", "tenantName", "propertyName"]
    }
  },
  "auth": {
    "providers": [
      "email-password"
    ]
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": {
        "$ref": "#/entities/Tenant"
      },
      "description": "Collection of all tenants."
    },
    "/properties/{propertyId}": {
        "schema": {
            "$ref": "#/entities/Property"
        },
        "description": "Collection of all properties."
    },
    "/payments/{paymentId}": {
      "schema": {
        "$ref": "#/entities/Payment"
      },
      "description": "Collection of all payments for easy querying across all tenants."
    }
  }
}
